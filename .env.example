# Supabase — copy this file to .env and fill in your project values.
# Found in: Supabase Dashboard -> Connect (top bar) -> App Frameworks,
# or Project Settings -> Data API.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# NOTE: The service_role key is NEVER placed here or in any client/.env file.
# It lives only in Supabase Edge Function secrets (set up in Phase 5).
